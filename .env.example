# Dark Web Leak Monitor - Environment Variables
# Copy this file to .env and fill in your values

# Chatbot API keys (priority: GROQ_API_KEY first, then OPENAI_API_KEY)
# Groq key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
#
# OpenAI key (fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini
SECRET_KEY=change-this-in-production

# ==================== FIREBASE (RAILWAY) ====================
# Use ONE of these:
# 1) FIREBASE_CREDENTIALS_JSON = full service account JSON (single-line)
# 2) FIREBASE_CREDENTIALS_BASE64 = base64-encoded service account JSON
# If both are empty, local file fallback is used (if present).
FIREBASE_CREDENTIALS_JSON=
# FIREBASE_CREDENTIALS_BASE64=

# ==================== FEEDBACK EMAIL CONFIGURATION ====================
# Gmail SMTP settings for sending feedback notifications
# 
# SETUP INSTRUCTIONS:
# 1. Enable 2-Factor Authentication on your Google Account:
#    https://myaccount.google.com/security
#
# 2. Generate an App Password:
#    https://myaccount.google.com/apppasswords
#    - Select "Mail" as the app
#    - Select your device
#    - Copy the 16-character password (no spaces needed)
#
# 3. Fill in the values below:

# Your Gmail address for sending feedback emails
FEEDBACK_EMAIL_ADDRESS=shubhamshin148@gmail.com

# Gmail App Password (NOT your regular Gmail password!)
# This is the 16-character password generated in step 2
FEEDBACK_EMAIL_PASSWORD=your_gmail_app_password_here

# Optional: Separate recipient email (defaults to FEEDBACK_EMAIL_ADDRESS)
# FEEDBACK_RECIPIENT_EMAIL=another@email.com
